# Copy to .env for local development (never commit the real .env file).

FLASK_ENV=development

# Generate real random values for these in production:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# Leave unset locally to use SQLite (instance/movex.db).
# On Render this is provided automatically by the managed Postgres database.
# DATABASE_URL=postgresql://user:password@host:5432/movex

# --- Admin seed account (used by `flask seed-db`) ---------------------------
ADMIN_EMAIL=admin@movex.app
ADMIN_PASSWORD=change-me
ADMIN_PHONE=+2340000000000

# --- Email (password reset / verification) ------------------------------------
# Leave MAIL_SUPPRESS_SEND=true to log emails to the console instead of
# sending them — useful until real SMTP credentials exist.
MAIL_SUPPRESS_SEND=true
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@movex.app

# --- Payments (leave blank until you have real merchant keys) ------------------
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# --- Rate limiting storage ------------------------------------------------------
# Use a real Redis URL in production so limits are shared across workers/dynos:
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=memory://

# --- Maps (public instances by default — self-host or use a paid provider
# for production volume) --------------------------------------------------------
OSM_NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_ROUTING_URL=https://router.project-osrm.org
